void delay_us(uint32_t us) {
    uint32_t start = DWT->CYCCNT;
    uint32_t ticks = us * (SystemCoreClock / 1000000);
    while ((DWT->CYCCNT - start) < ticks);
}

void lights_off(void) {
    HAL_GPIO_WritePin(GPIOA, RED2_PIN|RED3_PIN|RED4_PIN|BLUE3_PIN|BLUE4_PIN, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOB, BLUE1_PIN|BLUE2_PIN, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOC, RED1_PIN, GPIO_PIN_RESET);
}

uint8_t checkButton(void) {
    if (HAL_GPIO_ReadPin(BUTTON_PORT, BUTTON_PIN) == GPIO_PIN_RESET) {
        HAL_Delay(50);
        if (HAL_GPIO_ReadPin(BUTTON_PORT, BUTTON_PIN) == GPIO_PIN_RESET) {
            while(HAL_GPIO_ReadPin(BUTTON_PORT, BUTTON_PIN) == GPIO_PIN_RESET);
            currentSong = (currentSong + 1) % 5;
            lights_off();
            return 1;
        }
    }
    return 0;
}

void playTone(uint16_t freq, uint32_t ms) {
    if (freq == 0) { HAL_Delay(ms); return; }
    uint32_t period = 1000000 / freq;
    uint32_t startTime = HAL_GetTick();

    while ((HAL_GetTick() - startTime) < ms) {
        HAL_GPIO_WritePin(SPEAKER_PORT, SPEAKER_PIN, GPIO_PIN_SET);
        delay_us(period / 2);
        HAL_GPIO_WritePin(SPEAKER_PORT, SPEAKER_PIN, GPIO_PIN_RESET);
        delay_us(period / 2);
        if (HAL_GPIO_ReadPin(BUTTON_PORT, BUTTON_PIN) == GPIO_PIN_RESET) return;
    }
    HAL_GPIO_WritePin(SPEAKER_PORT, SPEAKER_PIN, GPIO_PIN_RESET);
    HAL_Delay(20);
}

void nextLED(void) {
    lights_off();
    switch (ledIndex) {
        case 0: HAL_GPIO_WritePin(GPIOC, RED1_PIN, GPIO_PIN_SET); break;
        case 1: HAL_GPIO_WritePin(GPIOA, RED2_PIN, GPIO_PIN_SET); break;
        case 2: HAL_GPIO_WritePin(GPIOA, RED3_PIN, GPIO_PIN_SET); break;
        case 3: HAL_GPIO_WritePin(GPIOA, RED4_PIN, GPIO_PIN_SET); break;
        case 4: HAL_GPIO_WritePin(GPIOB, BLUE1_PIN, GPIO_PIN_SET); break;
        case 5: HAL_GPIO_WritePin(GPIOB, BLUE2_PIN, GPIO_PIN_SET); break;
        case 6: HAL_GPIO_WritePin(GPIOA, BLUE3_PIN, GPIO_PIN_SET); break;
        case 7: HAL_GPIO_WritePin(GPIOA, BLUE4_PIN, GPIO_PIN_SET); break;
    }
    ledIndex = (ledIndex + 1) % 8;
}

uint32_t getFreq(char note) {
    switch(note) {
        case 'c': return 261; case 'd': return 294; case 'e': return 329;
        case 'f': return 349; case 'g': return 392; case 'a': return 440;
        case 'b': return 493; case 'C': return 523; case 'B': return 466;
        case 'A': return 440; default:  return 0;
    }
}

void playSirenPulse(uint16_t freq) {
    uint32_t period = 1000000 / freq;
    HAL_GPIO_WritePin(SPEAKER_PORT, SPEAKER_PIN, GPIO_PIN_SET);
    delay_us(period / 2);
    HAL_GPIO_WritePin(SPEAKER_PORT, SPEAKER_PIN, GPIO_PIN_RESET);
    delay_us(period / 2);
}

void runPolice(void) {
    uint16_t f;
    for (f = 600; f < 1400; f += 25) {
        if (checkButton()) return;
        if (f == 600) {
            HAL_GPIO_WritePin(GPIOC, RED1_PIN, GPIO_PIN_SET);
            HAL_GPIO_WritePin(GPIOA, RED2_PIN | RED3_PIN | RED4_PIN, GPIO_PIN_SET);
            HAL_GPIO_WritePin(GPIOB, BLUE1_PIN | BLUE2_PIN, GPIO_PIN_RESET);
            HAL_GPIO_WritePin(GPIOA, BLUE3_PIN | BLUE4_PIN, GPIO_PIN_RESET);
        } else if (f >= 1000) {
            HAL_GPIO_WritePin(GPIOC, RED1_PIN, GPIO_PIN_RESET);
            HAL_GPIO_WritePin(GPIOA, RED2_PIN | RED3_PIN | RED4_PIN, GPIO_PIN_RESET);
            HAL_GPIO_WritePin(GPIOB, BLUE1_PIN | BLUE2_PIN, GPIO_PIN_SET);
            HAL_GPIO_WritePin(GPIOA, BLUE3_PIN | BLUE4_PIN, GPIO_PIN_SET);
        }
        playSirenPulse(f);
    }
    for (f = 1400; f > 600; f -= 25) {
        if (checkButton()) return;
        playSirenPulse(f);
    }
}

